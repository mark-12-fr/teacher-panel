# AcadTrack Teacher — Next.js frontend environment.
# Copy to `.env.local` for local dev, or set these in the Vercel dashboard
# (Project Settings → Environment Variables). All NEXT_PUBLIC_* vars are baked
# into the client bundle at build time, so redeploy after changing them.

# Base URL of the FastAPI backend (your Render service). No trailing slash.
# Local dev falls back to http://127.0.0.1:5001 when this is unset.
NEXT_PUBLIC_API_BASE=https://teacher-panel-api.onrender.com

# Supabase project (used for Auth only — email/password, Google, OTP reset).
# These have safe public fallbacks in lib/supabase.ts, so they're optional.
NEXT_PUBLIC_SUPABASE_URL=https://njzvuwkepaasnsvuujgx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
