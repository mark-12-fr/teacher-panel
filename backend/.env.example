# ── AcadTrack Teacher API — environment ─────────────────────────────────────
# Async SQLAlchemy URL to the SAME Supabase Postgres (scheme postgresql+asyncpg).
# Supabase → Settings → Database → Connection string (pooler/transaction URI).
DATABASE_URL=

# Supabase JWT secret — verifies the access tokens the frontend gets from
# Supabase Auth. Supabase → Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_URL=https://njzvuwkepaasnsvuujgx.supabase.co

# Allowed frontend origins (comma-separated).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI assistant (at least one enables /api/ai-evaluate)
GROQ_API_KEY=
GEMINI_API_KEY=
# GROQ_MODEL=
# GEMINI_MODEL=

# Web Push / VAPID (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@acadtrack.app
